NODE_ENV=production
LOG_LEVEL=info
HOST=0.0.0.0
PORT=3000
ENABLE_HTTPS=false
ENABLE_HSTS=false

# PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/golx_main
# Use true for managed PostgreSQL requiring TLS; false for a trusted internal Docker network.
DATABASE_SSL=true
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_APPLICATION_NAME=goalix-api
DB_STATEMENT_TIMEOUT_MS=30000
DB_IDLE_IN_TRANSACTION_SESSION_TIMEOUT_MS=10000
DB_LOCK_TIMEOUT_MS=5000

# Redis / BullMQ / realtime
REDIS_PASSWORD=replace-with-a-secure-random-redis-password
REDIS_URL=redis://:replace-with-a-secure-random-redis-password@HOST:6379
REDIS_REQUIRED=true
BULLMQ_PREFIX=goalix
BULLMQ_ENABLED=true
BULLMQ_WORKERS_ENABLED=false
QUEUE_REDIS_FAILURE_MODE=throw
BACKGROUND_AUTOMATIONS_ENABLED=false
INJURY_RISK_AUTOMATION_ENABLED=false

# Auth secrets. Generate unique values; never reuse these examples.
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-another-32-random-characters
JWT_ACTIVE_KID=v1
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
COOKIE_SECRET=replace-with-at-least-32-random-characters
CSRF_SECRET=replace-with-at-least-32-random-characters
QR_ATTENDANCE_SECRET=replace-with-at-least-32-random-characters

# MFA / TOTP
TOTP_ISSUER=GOALIX Academy
MFA_ENFORCED_ROLES=admin,coach
# 32-byte base64 or 64-character hex.
TOTP_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# CORS
CORS_ORIGINS=http://your-server-ip-or-https-domain.example

# Security limits
BCRYPT_ROUNDS=12
API_RATE_LIMIT_MAX=1000
API_RATE_LIMIT_WINDOW_MINUTES=15
CHAT_WRITE_RATE_LIMIT_MAX=120
CHAT_WRITE_RATE_LIMIT_WINDOW_MINUTES=15
UPLOAD_RATE_LIMIT_MAX=60
UPLOAD_RATE_LIMIT_WINDOW_MINUTES=15
MAX_FAILED_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
ADMIN_MAX_FAILED_LOGIN_ATTEMPTS=3
ADMIN_LOCKOUT_DURATION_MINUTES=30

# Upload storage. Use s3 for production unless the host has a managed shared volume.
STORAGE_PROVIDER=s3
# Set true only when production uses a durable shared upload volume.
ALLOW_LOCAL_UPLOAD_STORAGE_IN_PRODUCTION=false
# Keep false in production after media_files metadata has been backfilled.
UPLOAD_LEGACY_METADATA_FALLBACK_ENABLED=false
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=goalix-uploads
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me

# Observability
SLOW_QUERY_LOG_MS=250
SLOW_QUERY_SQL_MAX_CHARS=2000
SLOW_REQUEST_LOG_MS=1000
METRICS_ENABLED=true
METRICS_TOKEN=replace-with-at-least-24-random-characters

# Backup targets used by the runbook.
BACKUP_DIR=backups
BACKUP_RPO_MINUTES=15
BACKUP_RTO_MINUTES=120
BACKUP_AUTOMATION_ENABLED=true
BACKUP_INTERVAL_MINUTES=1440
BACKUP_RETENTION_DAYS=14
# Keep false in production unless the restore button is intentionally enabled for a trusted admin environment.
BACKUP_RESTORE_ENABLED=false
DEMO_USER_PASSWORD=replace-with-a-secure-demo-password
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-secure-admin-password
BOOTSTRAP_ADMIN_EMAIL=admin@goalix.com
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_FULL_NAME=Goalix Admin
BOOTSTRAP_ACADEMY_NAME=Goalix Academy
# Set true only for intentional recovery/update when an admin already exists.
BOOTSTRAP_ADMIN_ALLOW_EXISTING=false
