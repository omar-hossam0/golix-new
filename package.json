{
  "name": "goalix",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "free:dev-ports": "node scripts/free-dev-ports.js",
    "models:setup": "node scripts/ensure-python-models.js",
    "redis:up": "node scripts/ensure-golx-redis.js",
    "infra:up": "docker compose -f docker-compose.dev.yml up -d redis",
    "infra:down": "docker compose -f docker-compose.dev.yml down",
    "infra:status": "docker compose -f docker-compose.dev.yml ps",
    "lan:setup": "powershell -ExecutionPolicy Bypass -File scripts/enable-lan-access.ps1",
    "lan:info": "node scripts/print-lan-urls.js",
    "dev": "node scripts/dev.js",
    "dev:frontend": "next dev -H 0.0.0.0 -p 3001",
    "dev:https": "node scripts/dev.js --https",
    "dev:frontend:https": "next dev --experimental-https -H 0.0.0.0 -p 3001",
    "dev:backend": "cd golx-backend && npm run dev",
    "deploy:auto": "powershell -ExecutionPolicy Bypass -File scripts/auto-docker-deploy.ps1",
    "deploy:auto:once": "powershell -ExecutionPolicy Bypass -File scripts/auto-docker-deploy.ps1 -Once",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "backend:lint": "cd golx-backend && npm run lint",
    "backend:test": "cd golx-backend && npm test",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium",
    "security:audit": "npm audit --audit-level=high && cd golx-backend && npm audit --audit-level=high",
    "security:scan-dumps": "node scripts/check-no-dumps.mjs",
    "quality:i18n": "node scripts/check-dashboard-i18n.mjs",
    "quality:text": "node scripts/check-text-artifacts.mjs",
    "quality:artifacts": "node scripts/check-no-model-artifacts.mjs",
    "quality": "npm run quality:i18n && npm run quality:text && npm run quality:artifacts && npm run security:scan-dumps",
    "verify": "npm run lint && npm run quality && npm run build && npm run backend:lint && npm run backend:test && npm run security:audit"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@reduxjs/toolkit": "^2.11.2",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "html5-qrcode": "^2.3.8",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.7.0",
    "next": "^16.2.9",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4",
    "react-redux": "^9.2.0",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "concurrently": "^9.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.10",
    "ws": "8.21.0"
  }
}
