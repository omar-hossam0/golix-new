# Frontend runtime
NODE_ENV=production
PORT=3001
HOSTNAME=0.0.0.0

# Production compose public ports. For the current IP-only deployment, HTTP is
# the public entrypoint. HTTPS can stay exposed only if a certificate exists.
HTTP_PORT=80
HTTPS_PORT=443
BACKEND_NODE_ENV=production

# Leave empty when the frontend and backend are served through the same domain by nginx.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_SOCKET_URL=

# HTTP-only IP deployments must keep these disabled. Enable them only after
# a real domain and trusted TLS certificate are configured.
ENABLE_HTTPS=false
ENABLE_HSTS=false
FORCE_HTTPS=false

# Server-side-only API URL used by Next.js server rendering and proxy routes.
# Docker production compose should use: http://api:3000
GOALIX_INTERNAL_API_URL=http://api:3000

# Backend production settings used by docker-compose.prod.yml.
POSTGRES_PASSWORD=replace-with-a-secure-random-password
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_REFRESH_SECRET=replace-with-another-32-random-characters
COOKIE_SECRET=replace-with-at-least-32-random-characters
CSRF_SECRET=replace-with-at-least-32-random-characters
TOTP_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
MFA_ENFORCED_ROLES=admin,coach

# HTTP-only IP deployment example: http://72.62.35.177
# HTTPS domain deployment example: https://goalix.example.com
CORS_ORIGINS=http://your-server-ip-or-https-domain.example

# Must match the backend JWT_SECRET. Used only by Next.js server/proxy code to
# verify signed access cookies before allowing protected dashboard routes.
GOALIX_ACCESS_JWT_SECRET=replace-with-the-same-value-as-backend-JWT_SECRET

TLS_CERT_PATH=./certificates/fullchain.pem
TLS_KEY_PATH=./certificates/privkey.pem

# Optional API proxy tuning for /api/v1/* Next.js proxy routes.
GOALIX_API_PROXY_MAX_SOCKETS=1024
GOALIX_API_PROXY_MAX_FREE_SOCKETS=128
GOALIX_API_PROXY_TIMEOUT_MS=90000
