# Frontend runtime
NODE_ENV=production
PORT=3001
HOSTNAME=0.0.0.0

# Leave empty when the frontend and backend are served through the same domain by nginx.
NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_SOCKET_URL=

# Server-side-only API URL used by Next.js server rendering and proxy routes.
# Docker production compose can use: http://api-1:3000
GOALIX_INTERNAL_API_URL=http://127.0.0.1:3000

# Must match the backend JWT_SECRET. Used only by Next.js server/proxy code to
# verify signed access cookies before allowing protected dashboard routes.
GOALIX_ACCESS_JWT_SECRET=replace-with-the-same-value-as-backend-JWT_SECRET

# Optional API proxy tuning for /api/v1/* Next.js proxy routes.
GOALIX_API_PROXY_MAX_SOCKETS=1024
GOALIX_API_PROXY_MAX_FREE_SOCKETS=128
GOALIX_API_PROXY_TIMEOUT_MS=90000
